<style>
/* Active page */
.navbar .nav-link.active {
  color: var(--global-theme-color) !important;
  font-weight: 700 !important;
}

/* Site title hizalama + stil */
.site-title {
  font-weight: 400 !important;
  margin-left: 0 !important;
}

/* Ekrem Cem bold */
.site-title strong {
  font-weight: 700;
}
</style>

<header class="navbar navbar-expand-lg navbar-light">
  <div class="container">

    <!-- SITE TITLE -->
    <a class="navbar-brand site-title" href="{{ '/' | relative_url }}">
      <strong>Ekrem Cem</strong> ÇANKIRILIGİL
    </a>

    <!-- NAV BUTTON -->
    <button
      class="navbar-toggler"
      type="button"
      data-toggle="collapse"
      data-target="#navbarNav"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- NAV LINKS -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ml-auto">

        {% for p in site.pages %}
          {% if p.nav == true %}

            {% assign url = p.url | relative_url %}

            <li class="nav-item">
              <a class="nav-link {% if page.url == p.url %}active{% endif %}" href="{{ url }}">
                {{ p.title | strip_html }}
              </a>
            </li>

          {% endif %}
        {% endfor %}

      </ul>
    </div>

  </div>
</header>
